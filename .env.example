# Copy to `.env` in the project root (same folder as package.json).
# Never commit `.env` — it is gitignored.
#
# Local dev: fill these and run `npm run dev`.
# GitHub Pages: add the same names as repository Secrets (Settings → Secrets and variables → Actions).
#
# Supabase → Project Settings → API:
#   VITE_SUPABASE_URL=https://xxxx.supabase.co
#   VITE_SUPABASE_ANON_KEY=eyJ... (anon public key)

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

